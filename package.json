  "bugs": {
    "url": "https://github.com/jkuhlemann/weekly-testing-report/issues"
  },
  "homepage": "https://github.com/jkuhlemann/weekly-testing-report#readme",
  "dependencies": {
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0"
  }
}
