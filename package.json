{
  "name": "weekly-testing-report",
  "version": "1.0.0",
  "description": "Google Sheets fetch script for weekly testing reports",
  "main": "fetchTestSheet.js",
  "scripts": {
    "fetch:sheet": "node fetchTestSheet.js",
    "fetch:checkly": "node fetchChecklyGroups.js",
    "slack:checkly:blocks": "node printChecklySlackBlocks.js",
    "slack:checkly:preview": "node fetchChecklyGroups.js | node printChecklySlackBlocks.js",
    "report": "node buildWeeklyReport.js",
    "report:slack": "node buildWeeklyReport.js | node postSlackWebhook.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkuhlemann/weekly-testing-report.git"
  },
  "keywords": [],
