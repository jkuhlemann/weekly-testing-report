GOOGLE_SHEETS_SPREADSHEET_ID=
# Or use the full Google Sheets URL instead:
# GOOGLE_SHEETS_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your-sheet-id/edit

GOOGLE_SHEETS_RANGE=Sheet1!A:Z
GOOGLE_SHEETS_MAJOR_DIMENSION=ROWS
GOOGLE_SHEETS_VALUE_RENDER_OPTION=FORMATTED_VALUE
GOOGLE_SHEETS_DATE_TIME_RENDER_OPTION=SERIAL_NUMBER

# Option 1: public sheet access with an API key
GOOGLE_SHEETS_API_KEY=

# Option 2: private sheet access with a service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option 3: private sheet access with inline service account credentials
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Checkly (optional — enables checklyApiGroupReport in fetch:sheet output)
# API key: https://app.checklyhq.com/settings/user/api-keys
# Account ID: https://app.checklyhq.com/settings/account/general
CHECKLY_API_KEY=
CHECKLY_ACCOUNT_ID=
# Numeric group id from the Checkly UI URL (.../groups/<id>/...)
CHECKLY_CHECK_GROUP_ID=3930727

# Optional: limit stale-manual-test warnings to rows where this column matches GOOGLE_SHEETS_MANUAL_TEST_VALUES (e.g. column "execution" = manual). If unset, all rows count as manual.
# GOOGLE_SHEETS_MANUAL_TEST_COLUMN=execution
# GOOGLE_SHEETS_MANUAL_TEST_VALUES=manual

# Slack — post weekly report (local: npm run report:slack)
# Webhook: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
# SLACK_REPORT_TITLE=Weekly Testing Report
